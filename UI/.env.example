# Leave blank to use the Vite dev proxy (forwards /negotiations/* and /config to
# the FastAPI backend at localhost:8000 — see vite.config.js). Set this to hit
# a deployed backend directly, e.g. https://your-api.example.com
VITE_API_BASE=

# Set to "true" to run the UI against the local mock (mock.js) instead of the
# real backend. Useful for frontend-only development without the backend running.
VITE_USE_MOCK=false
