# Pioneer.ai (Promise Platform) — get your key at pioneer.ai -> Settings -> API Keys
PIONEER_API_KEY=pio_sk_...
# Model ID: use the training_job_id of a deployed fine-tuned model, or a base model name
# (e.g. "gpt-4.1-mini"). See eval/pioneer_mlops.py and PIONEER_SETUP.md.
PIONEER_MODEL=gpt-4.1-mini

# ClickHouse (BE-7) — leave blank to disable telemetry (negotiation still works)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true
